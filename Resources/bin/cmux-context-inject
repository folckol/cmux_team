#!/bin/bash
# cmux-context-inject: generates a context summary for AI agent injection.
# Called before launching Claude Code in a cmux workspace.
# Outputs markdown to stdout that can be appended to CLAUDE.md or passed as --context-file.

set -euo pipefail

SOCKET_PATH="${CMUX_CONTEXT_SOCKET_PATH:-$HOME/.config/cmux/context.sock}"
MAX_SIZE="${CMUX_CONTEXT_MAX_INJECT_SIZE:-4096}"
PROJECT_ROOT="${CMUX_PROJECT_ROOT:-$PWD}"
ME_FILE="$PROJECT_ROOT/.cmux_team/me.json"
PROMPT_FILE="$PROJECT_ROOT/.cmux_team/system_prompt.md"
CONN_FILE="$PROJECT_ROOT/.cmux_team/connection.json"

# Check if daemon is running
if [ ! -S "$SOCKET_PATH" ]; then
    exit 0
fi

# Read current user identity if present
ME_JSON=""
if [ -f "$ME_FILE" ]; then
    ME_JSON=$(cat "$ME_FILE" 2>/dev/null || echo "")
fi

# Resolve active team-context project:
# CMUX_CONTEXT_PROJECT env > connection.json project_id > empty (daemon uses default)
PROJECT_ID="${CMUX_CONTEXT_PROJECT:-}"
if [ -z "$PROJECT_ID" ] && [ -f "$CONN_FILE" ]; then
    PROJECT_ID=$(python3 -c "
import sys, json
try:
    with open('$CONN_FILE') as f: d = json.load(f)
    print(d.get('project_id', ''))
except Exception:
    pass
" 2>/dev/null)
fi

# Helper: send RPC and extract result; auto-injects project_id into params
# (unless params already provides one). Skips injection for scopeless methods.
rpc_call() {
    local method="$1"
    local params="$2"
    local final_params
    final_params=$(PROJECT_ID="$PROJECT_ID" METHOD="$method" PARAMS="$params" python3 -c "
import os, json, sys
method = os.environ['METHOD']
pid = os.environ.get('PROJECT_ID', '')
scopeless = {'auth','ping','hello',
             'context.project.list','context.project.create','context.project.rename','context.project.delete',
             'context.user.list','context.user.create','context.user.get','context.user.delete'}
try:
    p = json.loads(os.environ['PARAMS']) if os.environ['PARAMS'] else {}
except Exception:
    p = {}
if pid and method not in scopeless and 'project_id' not in p:
    p['project_id'] = pid
sys.stdout.write(json.dumps(p))
" 2>/dev/null)
    echo "{\"id\":1,\"method\":\"$method\",\"params\":$final_params}" | \
        nc -U "$SOCKET_PATH" 2>/dev/null | \
        python3 -c "
import sys, json
try:
    resp = json.loads(sys.stdin.read())
    if resp.get('ok'):
        json.dump(resp.get('result', {}), sys.stdout)
except:
    pass
" 2>/dev/null
}

output=""

# Project-specific system prompt (edited in Team Context → Settings)
if [ -f "$PROMPT_FILE" ]; then
    prompt_body=$(cat "$PROMPT_FILE" 2>/dev/null)
    if [ -n "$prompt_body" ]; then
        output+="$prompt_body"
        output+="\n\n---\n\n"
    fi
fi

# Identity header
if [ -n "$ME_JSON" ]; then
    output+=$(echo "$ME_JSON" | python3 -c "
import sys, json
try:
    me = json.loads(sys.stdin.read())
    print(f'## Your Identity\n\nYou are acting on behalf of **{me.get(\"name\", \"unknown\")}** (role: {me.get(\"role\", \"none\")}). All context changes you make MUST be attributed to this user. Pass --author={me.get(\"user_id\", \"\")} or set user_id when calling cmux context commands.\n')
except Exception:
    pass
" 2>/dev/null)
    output+="\n"
fi

# Team roster
user_data=$(rpc_call "context.user.list" '{}')
if [ -n "$user_data" ]; then
    users_count=$(echo "$user_data" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(len(d.get('users',[])))" 2>/dev/null || echo "0")
    if [ "$users_count" -gt 0 ]; then
        output+="## Team Members\n\n"
        output+=$(echo "$user_data" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
for u in d.get('users', []):
    role = f' — {u[\"role\"]}' if u.get('role') else ''
    print(f'- **{u[\"name\"]}**{role} (id: {u[\"id\"][:8]})')
" 2>/dev/null)
        output+="\n\n"
    fi
fi

# Recent team activity (last 15 events)
events_data=$(rpc_call "context.event.list" '{"limit":15}')
if [ -n "$events_data" ]; then
    events_count=$(echo "$events_data" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(len(d.get('events',[])))" 2>/dev/null || echo "0")
    if [ "$events_count" -gt 0 ]; then
        output+="## Recent Team Activity (latest 15)\n\n"
        output+=$(echo "$events_data" | python3 -c "
import sys, json, time
d = json.loads(sys.stdin.read())
for e in d.get('events', []):
    ts = e.get('ts', 0)
    age_min = int((time.time() - ts) / 60)
    age = f'{age_min}m ago' if age_min < 60 else f'{age_min // 60}h ago'
    uid = (e.get('user_id','') or '?')[:8]
    summary = e.get('summary', '')
    tail = f' — {summary}' if summary else ''
    print(f'- [{age}] {uid} {e.get(\"action\",\"\")} {e.get(\"kind\",\"\")} {e.get(\"target_id\",\"\")[:16]}{tail}')
" 2>/dev/null)
        output+="\n\n"
    fi
fi

# Active edit locks
lock_data=$(rpc_call "context.lock.list" '{}')
if [ -n "$lock_data" ]; then
    lock_count=$(echo "$lock_data" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(len(d.get('locks',[])))" 2>/dev/null || echo "0")
    if [ "$lock_count" -gt 0 ]; then
        output+="## ⚠ Being Edited Right Now (don't touch)\n\n"
        output+=$(echo "$lock_data" | python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
for l in d.get('locks', []):
    print(f'- {l[\"kind\"]}:{l[\"target_id\"][:16]} — by {l[\"user_name\"]}')
" 2>/dev/null)
        output+="\n\n"
    fi
fi

# KV entries
kv_data=$(rpc_call "context.kv.list" '{}')
if [ -n "$kv_data" ]; then
    kv_count=$(echo "$kv_data" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(len(d.get('entries',[])))" 2>/dev/null || echo "0")
    if [ "$kv_count" -gt 0 ]; then
        output+="## Team Context: Key-Value Entries\n\n"
        output+=$(echo "$kv_data" | python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
for e in data.get('entries', []):
    cat = f' [{e[\"category\"]}]' if e.get('category') else ''
    print(f'- **{e[\"key\"]}**{cat}: {e[\"value\"]}')
" 2>/dev/null)
        output+="\n\n"
    fi
fi

# Documents (titles and categories only for summary)
doc_data=$(rpc_call "context.doc.list" '{"limit":20}')
if [ -n "$doc_data" ]; then
    doc_count=$(echo "$doc_data" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(len(d.get('documents',[])))" 2>/dev/null || echo "0")
    if [ "$doc_count" -gt 0 ]; then
        output+="## Team Context: Documents\n\n"
        output+="Use \`cmux context doc show <id>\` to read full documents.\n\n"
        output+=$(echo "$doc_data" | python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
for d in data.get('documents', []):
    cat = f' [{d[\"category\"]}]' if d.get('category') else ''
    print(f'- {d[\"title\"]}{cat} (id: {d[\"id\"][:8]}...)')
" 2>/dev/null)
        output+="\n\n"
    fi
fi

# Entities summary
entity_data=$(rpc_call "context.entity.list" '{}')
if [ -n "$entity_data" ]; then
    entity_count=$(echo "$entity_data" | python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(len(d.get('entities',[])))" 2>/dev/null || echo "0")
    if [ "$entity_count" -gt 0 ]; then
        output+="## Team Context: Knowledge Graph\n\n"
        output+=$(echo "$entity_data" | python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
types = {}
for e in data.get('entities', []):
    t = e.get('type', 'unknown')
    types.setdefault(t, []).append(e['name'])
for t, names in sorted(types.items()):
    print(f'### {t.capitalize()}s')
    for n in names:
        print(f'- {n}')
    print()
" 2>/dev/null)
        output+="\n"
    fi
fi

# Truncate to max size
if [ ${#output} -gt "$MAX_SIZE" ]; then
    output="${output:0:$MAX_SIZE}"
    output+="\n\n*[Context truncated. Use \`cmux context show\` for full data.]*\n"
fi

# Output
if [ -n "$output" ]; then
    echo -e "\n# Team Context (auto-injected by cmux)\n"
    echo -e "$output"
    echo -e "---\n*Use \`cmux context\` CLI to query and update team context.*\n"
fi
